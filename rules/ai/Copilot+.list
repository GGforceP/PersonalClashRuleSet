# =========================================
# Microsoft Copilot+（优化版 2026.04）
# 专注 Copilot 网页 / M365 / Studio / API
# 已包含 cloud.microsoft 迁移域名
# =========================================

# =========================================
# 主站 / 聊天入口
# =========================================
DOMAIN-SUFFIX,copilot.microsoft.com
DOMAIN-SUFFIX,copilot.cloud.microsoft     # 【2026 新主入口】
DOMAIN-SUFFIX,copilot.microsoft

# =========================================
# M365 Copilot & 云服务
# =========================================
DOMAIN-SUFFIX,cloud.microsoft             # 2026 全面迁移核心域名
DOMAIN-SUFFIX,m365.cloud.microsoft

# =========================================
# Bing 搜索 grounding（必要，Copilot 依赖）
# =========================================
DOMAIN-SUFFIX,bing.com
DOMAIN-SUFFIX,bingapis.com
DOMAIN,chat.bing.com
DOMAIN,copilotsearch.bing.com

# =========================================
# API / 后端服务
# =========================================
DOMAIN-SUFFIX,api.copilot.microsoft.com
DOMAIN-SUFFIX,graph.microsoft.com         # Microsoft Graph Copilot API
DOMAIN-SUFFIX,copilotstudio.microsoft.com # Copilot Studio
DOMAIN-SUFFIX,ai.azure.com                # Azure OpenAI 后端
DOMAIN-SUFFIX,openai.azure.com

# =========================================
# 账号 / 登录 / 认证
# =========================================
DOMAIN-SUFFIX,login.microsoftonline.com
DOMAIN-SUFFIX,account.microsoft.com
DOMAIN-SUFFIX,login.live.com

# =========================================
# 静态资源 / CDN
# =========================================
DOMAIN-SUFFIX,cdn.copilot.microsoft.com
DOMAIN-SUFFIX,assets.copilot.microsoft.com
DOMAIN-SUFFIX,static.copilot.microsoft.com
DOMAIN-SUFFIX,edge.microsoft.com
DOMAIN-SUFFIX,azureedge.net               # 常用 Azure CDN

# =========================================
# 遥测 / 事件 / 监控（强烈建议保留，避免卡顿）
# =========================================
DOMAIN-SUFFIX,events.copilot.microsoft.com
DOMAIN-SUFFIX,metrics.copilot.microsoft.com
DOMAIN-SUFFIX,telemetry.microsoft.com

# =========================================
# 其他必要服务
# =========================================
DOMAIN-SUFFIX,office.com                  # 过渡期仍会用到
DOMAIN-SUFFIX,office.net

# =========================================
# 兜底（覆盖所有剩余 *.copilot.microsoft.* 和 cloud.microsoft 子域）
# =========================================
DOMAIN-SUFFIX,copilot.microsoft.com
DOMAIN-SUFFIX,cloud.microsoft

# =========================================
# END
# =========================================
