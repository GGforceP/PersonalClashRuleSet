DOMAIN,telemetry.microsoft.com
DOMAIN,events.data.microsoft.com
DOMAIN,browser.events.data.microsoft.com

# =========================================
# Bing / 搜索增强（Copilot 核心依赖，保留全量）
# =========================================
DOMAIN-SUFFIX,bing.com
DOMAIN,api.bing.com
DOMAIN,bingapis.azure-api.net
DOMAIN,api.cognitive.microsoft.com
DOMAIN,ssl.bing.com
DOMAIN,assets.bing.com
