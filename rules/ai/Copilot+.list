# =========================================
# Microsoft Copilot / M365 Copilot (优化版 2026.03)
# 精准聚焦 Copilot 核心，保留 Bing 搜索必需，新增 cloud.microsoft 新入口
# 避免过度代理无关 Office 服务
# =========================================

# =========================================
# Copilot 主站 / 新入口（2026 最重要）
# =========================================
DOMAIN-SUFFIX,copilot.microsoft.com
DOMAIN,copilot.cloud.microsoft
DOMAIN,m365.cloud.microsoft
DOMAIN,m365copilot.com
DOMAIN,www.copilot.microsoft.com
DOMAIN,copilot.microsoft365.com
DOMAIN,copilot.office.com
DOMAIN,copilot.teams.microsoft.com
DOMAIN,copilot.edge.microsoft.com

# =========================================
# Copilot API / 服务端
# =========================================
DOMAIN,api.copilot.microsoft.com
DOMAIN,prod.api.copilot.microsoft.com
DOMAIN,copilot-api.bing.com
DOMAIN,copilot.bing.com
DOMAIN,api.copilot.microsoft.com

# =========================================
# Copilot Studio / Agents / 插件平台
# =========================================
DOMAIN,studio.copilot.microsoft.com
DOMAIN,plugins.copilot.microsoft.com
DOMAIN,copilotstudio.microsoft.com

# =========================================
# M365 Copilot 集成（新）
