# =========================================
DOMAIN,graph.microsoft.com
DOMAIN,graph.microsoft.us

# =========================================
# 账号登录（必需，不能省）
# =========================================
DOMAIN,login.microsoftonline.com
DOMAIN,account.microsoft.com
DOMAIN,auth.microsoft.com

# =========================================
# 静态资源 / CDN
# =========================================
DOMAIN,assets.copilot.microsoft.com
DOMAIN-SUFFIX,microsoftusercontent.com
DOMAIN,contentstorage.microsoft.com
DOMAIN,msftstatic.com
DOMAIN,cdn.office.net
DOMAIN,officecdn.microsoft.com

# =========================================
