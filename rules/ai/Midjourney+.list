# =========================================
# Midjourney / Niji Journey + Discord (优化版 2026.03)
# Web 平台优先 + Niji 独立站点 + Discord 必要依赖
# 精准匹配，避免多余流量，未来-proof
# =========================================

# =========================================
# Midjourney 主站 / Web App（2026 强烈推荐）
# =========================================
DOMAIN-SUFFIX,midjourney.com
DOMAIN,www.midjourney.com
DOMAIN,docs.midjourney.com
DOMAIN,help.midjourney.com
DOMAIN,explore.midjourney.com
DOMAIN,account.midjourney.com

# =========================================
# Niji Journey（2026 新增，Niji 7 专用）
# =========================================
DOMAIN-SUFFIX,nijijourney.com
DOMAIN,www.nijijourney.com

# =========================================
# Midjourney API / 生成 / 任务 / 队列
# =========================================
DOMAIN,api.midjourney.com
DOMAIN,task.midjourney.com
DOMAIN,queue.midjourney.com

# =========================================
# Midjourney CDN / 静态 / 图片资源
# =========================================
DOMAIN,cdn.midjourney.com
DOMAIN,assets.midjourney.com
DOMAIN-SUFFIX,mj.gallery
DOMAIN-SUFFIX,mj.run

# =========================================
# Discord（Midjourney Bot 核心依赖 - 精简必要部分）
# =========================================
# 主站 & 邀请
DOMAIN-SUFFIX,discord.com
DOMAIN-SUFFIX,discord.gg
DOMAIN,discord.gg
DOMAIN,discordapp.com
DOMAIN,discordapp.net

# Gateway / 实时通信 / API
DOMAIN,gateway.discord.gg
DOMAIN,remote-auth-gateway.discord.gg
DOMAIN,api.discord.com

# CDN / 媒体 / 用户内容（MJ 生成图重度依赖）
DOMAIN,cdn.discordapp.com
DOMAIN,cdn.discordapp.net
DOMAIN,media.discordapp.net
DOMAIN-SUFFIX,discordusercontent.com
DOMAIN-SUFFIX,discord.media

# 语音（可选，如果不语音聊天可删掉）
# DOMAIN,rtc.discord.gg
# DOMAIN,voice.discord.gg

# =========================================
# 兜底（覆盖未来新子域）
# =========================================
DOMAIN-SUFFIX,midjourney.com
DOMAIN-SUFFIX,nijijourney.com

# =========================================
# END
